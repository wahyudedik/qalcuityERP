APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache Configuration
# Recommended: Use Redis for production (much faster than database)
CACHE_STORE=database
# CACHE_PREFIX=qalcuity-erp-cache

# For development (file-based, no external dependencies)
# CACHE_STORE=file

# For production (Redis - HIGHLY RECOMMENDED for AI optimization)
# CACHE_STORE=redis
# REDIS_CACHE_CONNECTION=cache
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# AI Optimization Settings
# Enable response caching to reduce Gemini API calls and costs
AI_RESPONSE_CACHE_ENABLED=true
AI_RESPONSE_CACHE_TTL=3600  # Default cache TTL in seconds (1 hour)

# Enable rule-based responses for simple queries (no API call needed)
AI_RULE_BASED_ENABLED=true

# Batch processing settings
AI_BATCH_SIZE=10  # Maximum messages per batch
AI_BATCH_QUEUE=ai  # Queue name for batch processing

# Streaming settings
AI_STREAMING_ENABLED=true
AI_STREAM_CHUNK_DELAY=50  # Delay between chunks in milliseconds (for typewriter effect)

# Redis Configuration (for cache & sessions)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@qalcuityerp.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Shipping (RajaOngkir via Komerce)
RAJAONGKIR_API_KEY=
RAJAONGKIR_TIER=starter

# Bot Integration
TELEGRAM_BOT_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# Payment Gateway — Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Payment Gateway — Xendit
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# WhatsApp — Fonnte
FONNTE_TOKEN=

# Push Notifications (VAPID)
# Generate with: php artisan vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback 

SLACK_ERROR_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ERROR_ALERT_EMAIL_RECIPIENTS=admin@example.com
LOG_DB_LEVEL=error
LOG_ALERT_LEVEL=critical