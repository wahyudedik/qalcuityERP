    <div class="bg-[#0f172a] border border-white/10 rounded-2xl w-full max-w-3xl max-h-[90vh] flex flex-col shadow-2xl">

        {{-- Header --}}
        <div class="flex items-start justify-between gap-4 px-6 py-4border-b border-white/10 shrink-0">
