APP_NAME="Qalcuity ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta 

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qalcuity_erp
DB_USERNAME=root
DB_PASSWORD=

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_STRICT=true
DB_ENGINE=InnoDB

# Migration performance optimization
MIGRATION_DISABLE_FOREIGN_KEYS=true
MIGRATION_SINGLE_TRANSACTION=false
MIGRATION_BATCH_SIZE=0

# ─────────────────────────────────────────────────
# SESSION, CACHE, QUEUE
# ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─────────────────────────────────────────────────
# REDIS (optional, recommended for production)
# ─────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ─────────────────────────────────────────────────
# VITE
# ─────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════════════
# ⚙️  SYSTEM CONFIGURATIONS
# ═══════════════════════════════════════════════════════════════════
# Catatan: SEMUA API pihak ketiga dikelola via Settings panel
# 
# 🔑 SuperAdmin Panel (/super-admin/settings):
#   - AI / Gemini API
#   - Google OAuth
#   - Push Notifications (VAPID)
#   - Error Alerts (Slack/Email)
#   - Mail/SMTP (Production)
#
# 🏢 Tenant Settings (Settings > Integrations):
#   - Payment Gateways (Midtrans, Xendit, Duitku)
#   - E-Commerce (Shopee, Tokopedia, Lazada)
#   - Shipping (RajaOngkir, JNE, J&T)
#   - WhatsApp (Fonnte, Business API)
#   - Telegram Bot
#   - Accounting (Jurnal.id, Accurate)
#   - Logistics (JNE, Sicepat)
#   - CCTV/NVR, Face Recognition
#   - Weather API
#
# .env values di bawah hanya untuk FALLBACK/Development
# ═══════════════════════════════════════════════════════════════════

# ── AI / Gemini (SuperAdmin panel) ─────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=60

AI_RESPONSE_CACHE_ENABLED=true
AI_CACHE_SHORT_TTL=300
AI_CACHE_DEFAULT_TTL=3600
AI_CACHE_LONG_TTL=86400

# ── Google OAuth (SuperAdmin panel) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback

# ── Push Notifications VAPID (SuperAdmin panel) ────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Error Alerts (SuperAdmin panel) ────────────────────────────
SLACK_ERROR_WEBHOOK_URL=
ERROR_ALERT_EMAIL_RECIPIENTS=admin@example.com
LOG_DB_LEVEL=error
LOG_ALERT_LEVEL=critical

# ── Mail/SMTP (Development only - Production via SuperAdmin) ───
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@qalcuityerp.com"
MAIL_FROM_NAME="${APP_NAME}"

