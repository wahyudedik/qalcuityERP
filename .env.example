APP_NAME="Qalcuity ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Super Admin credentials (used by SuperAdminSeeder)
SUPER_ADMIN_PASSWORD=

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qalcuity_erp
DB_USERNAME=root
DB_PASSWORD=

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_STRICT=true
DB_ENGINE=InnoDB

# Migration performance optimization
MIGRATION_DISABLE_FOREIGN_KEYS=true
MIGRATION_SINGLE_TRANSACTION=false
MIGRATION_BATCH_SIZE=0

# ─────────────────────────────────────────────────
# SESSION, CACHE, QUEUE
# ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null          # Set to .yourdomain.test for local dev
SESSION_SAME_SITE=lax        # lax, strict, none
SESSION_SECURE_COOKIE=false  # Set true for HTTPS production

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─────────────────────────────────────────────────
# REDIS (optional, recommended for production)
# ─────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ─────────────────────────────────────────────────
# VITE
# ─────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5173          # Port dev server (opsional, default 5173)

# ═══════════════════════════════════════════════════════════════════
# ⚙️  SYSTEM CONFIGURATIONS
# ═══════════════════════════════════════════════════════════════════
# Catatan: SEMUA API pihak ketiga dikelola via Settings panel
#
# 🔑 SuperAdmin Panel (/super-admin/settings):
#   - AI / Gemini API
#   - Google OAuth
#   - Push Notifications (VAPID)
#   - Error Alerts (Slack/Email)
#   - Mail/SMTP (Production)
#
# 🏢 Tenant Settings (Settings > Integrations):
#   - Payment Gateways (Midtrans, Xendit, Duitku)
#   - E-Commerce (Shopee, Tokopedia, Lazada)
#   - Shipping (RajaOngkir, JNE, J&T)
#   - WhatsApp (Fonnte, Business API)
#   - Telegram Bot
#   - Accounting (Jurnal.id, Accurate)
#   - Logistics (JNE, Sicepat)
#   - CCTV/NVR, Face Recognition
#   - Weather API
#
# .env values di bawah hanya untuk FALLBACK/Development
# ═══════════════════════════════════════════════════════════════════

# ── AI Provider (SuperAdmin panel) ─────────────────────────────
AI_DEFAULT_PROVIDER=gemini
AI_PROVIDER_MODE=failover

# ── Gemini ──────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=60

# ── Anthropic Claude ────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT=60
ANTHROPIC_MAX_TOKENS=8192

AI_RESPONSE_CACHE_ENABLED=true
AI_CACHE_SHORT_TTL=300
AI_CACHE_DEFAULT_TTL=3600
AI_CACHE_LONG_TTL=86400

# ── AI Use-Case Routing Thresholds ─────────────────────────────
# Cost threshold per tenant per month (IDR)
AI_COST_THRESHOLD_IDR=1000000

# Response time threshold (milliseconds)
AI_RESPONSE_TIME_THRESHOLD_MS=30000

# ── Google OAuth (SuperAdmin panel) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback

# ── Push Notifications VAPID (SuperAdmin panel) ────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY_DEV=
VAPID_PRIVATE_KEY_DEV=
VAPID_PUBLIC_KEY_PROD=
VAPID_PRIVATE_KEY_PROD=

# ── Error Alerts (SuperAdmin panel) ────────────────────────────
SLACK_ERROR_WEBHOOK_URL=
ERROR_ALERT_EMAIL_RECIPIENTS=admin@example.com
LOG_DB_LEVEL=error
LOG_ALERT_LEVEL=critical

# ── Mail/SMTP (Development only - Production via SuperAdmin) ───
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@qalcuityerp.com"
MAIL_FROM_NAME="${APP_NAME}"

