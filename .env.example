APP_NAME="Qalcuity ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qalcuity_erp
DB_USERNAME=root
DB_PASSWORD=

# Performance optimization for migrations
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_STRICT=true
DB_ENGINE=InnoDB

# Migration performance optimization
MIGRATION_DISABLE_FOREIGN_KEYS=true
MIGRATION_SINGLE_TRANSACTION=false
MIGRATION_BATCH_SIZE=0

# ─────────────────────────────────────────────────
# SESSION, CACHE, QUEUE
# ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache: use 'redis' in production for better performance
CACHE_STORE=database
# CACHE_STORE=redis

# ─────────────────────────────────────────────────
# REDIS (optional, recommended for production)
# ─────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ─────────────────────────────────────────────────
# VITE
# ─────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════════════
# ⚠️  SUPERADMIN-MANAGED SETTINGS (via /super-admin/settings panel)
# ═══════════════════════════════════════════════════════════════════
# The following configs are managed via the SuperAdmin Settings panel
# stored in the `system_settings` database table (encrypted).
#
# Values below are used as FALLBACK only when the DB setting is empty.
# In production, configure these via the SuperAdmin panel, NOT in .env.
# ═══════════════════════════════════════════════════════════════════

# ── AI / Gemini (owner pays, all tenants share) ──────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=60

AI_RESPONSE_CACHE_ENABLED=true
AI_CACHE_SHORT_TTL=300
AI_CACHE_DEFAULT_TTL=3600
AI_CACHE_LONG_TTL=86400
AI_RULE_BASED_ENABLED=true
AI_BATCH_SIZE=10
AI_BATCH_QUEUE=ai
AI_BATCH_MAX_CHUNKS=5
AI_STREAMING_ENABLED=true
AI_STREAM_CHUNK_DELAY=50
AI_STREAM_CHUNK_SIZE=50
AI_OPTIMIZATION_LOGGING=true
AI_COST_TRACKING_ENABLED=true

# ── Email / SMTP ─────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@qalcuityerp.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Google OAuth (Login dengan Google) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback

# ── Push Notifications (VAPID) ───────────────────────────────────
# Generate via SuperAdmin panel or: php artisan vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Error Alerts (owner notifications) ───────────────────────────
SLACK_ERROR_WEBHOOK_URL=
ERROR_ALERT_EMAIL_RECIPIENTS=admin@example.com
LOG_DB_LEVEL=error
LOG_ALERT_LEVEL=critical

# ── AWS S3 (if using cloud storage) ──────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ═══════════════════════════════════════════════════════════════════
# 🏢  TENANT-MANAGED SETTINGS (tenant sets via their ERP dashboard)
# ═══════════════════════════════════════════════════════════════════
# The following are NOT needed in .env — each tenant configures them
# via their own Settings > Integrations panel in the ERP.
#
# These are stored in the `tenant_api_settings` table per tenant.
# The .env values below are only for development/fallback purposes.
# ═══════════════════════════════════════════════════════════════════

# ── WhatsApp Bot (Fonnte) — tenant setup sendiri ─────────────────
# FONNTE_TOKEN=

# ── Telegram Bot — tenant setup sendiri ─────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── WhatsApp Access Token — tenant setup sendiri ─────────────────
# WHATSAPP_ACCESS_TOKEN=

# ── Weather API (untuk modul pertanian) — tenant setup sendiri ───
# WEATHER_API_KEY=

# ── CCTV / NVR — tenant setup sendiri ────────────────────────────
# CCTV_NVR_URL=http://192.168.1.100:8000
# CCTV_API_KEY=

# ── Face Recognition Service — tenant setup sendiri ──────────────
# FACE_RECOGNITION_URL=http://localhost:5000
# FACE_RECOGNITION_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# ✅  ALREADY IN TENANT DB (no .env needed)
# ═══════════════════════════════════════════════════════════════════
# Payment Gateway (Midtrans/Xendit/Duitku)  → TenantPaymentGateway model
# E-Commerce (Shopee/Tokopedia/Lazada)       → EcommercePlatform model
# Logistik (JNE/JNT/Sicepat/RajaOngkir)     → LogisticsProvider model
# Akuntansi (Jurnal.id/Accurate Online)      → AccountingIntegration model
# WhatsApp Business API                       → CommunicationChannel model
# MikroTik/Router (Telecom module)            → NetworkDevice model
# ═══════════════════════════════════════════════════════════════════
